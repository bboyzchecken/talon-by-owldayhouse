# Example .htaccess for an Apache static host.
# Upload this to the site root as ".htaccess" (rename it).
# Safe to skip on hosts that aren't Apache (Cloudflare Pages, Nginx, etc.).

# --- gzip ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain application/javascript application/json image/svg+xml application/manifest+json
</IfModule>

# --- caching ---
<IfModule mod_headers.c>
  # Content-hashed Next.js assets never change → cache forever.
  <If "%{REQUEST_URI} =~ m#^/_next/static/#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </If>
  # HTML must revalidate so new deploys show up immediately.
  <ElseIf "%{REQUEST_URI} =~ m#\.html$# || %{REQUEST_URI} =~ m#/$#">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </ElseIf>
</IfModule>

# --- routing (output: 'export' with trailingSlash: true) ---
# Serve directory index files; mod_dir adds the trailing slash for /about -> /about/.
DirectoryIndex index.html
<IfModule mod_dir.c>
  DirectorySlash On
</IfModule>

# Custom 404 page generated by Next.
ErrorDocument 404 /404.html

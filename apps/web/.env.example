# apps/web — copy to .env.local and fill in (never commit real values)

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Set to enable GA.
# NOTE: NEXT_PUBLIC_* is inlined at build time → set this BEFORE `pnpm build:web`
# so it ships in the static export. Leave empty to disable analytics.
NEXT_PUBLIC_GA_ID=

# Base URL for the ODH Go API, consumed by @odh/query in the Talon dashboard.
# Not used by this static marketing site; safe to leave empty here.
NEXT_PUBLIC_API_URL=
